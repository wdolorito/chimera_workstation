{
	"height": 30,
	"modules-left": ["wlr/taskbar"],
	"modules-right": ["idle_inhibitor", "wireplumber", "network", "cpu", "memory", "backlight", "battery", "clock"],
	"wlr/taskbar": {
		"format": "{name}",
		"tooltip": "{title}",
		"on-click": "minimize-raise",
		"rewrite": {
			"VSCodium - URL Handler": "VSCodium"
		}
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": " ",
			"deactivated": " "
		}
	},
	"wireplumber": {
			"format": "{volume}% {icon}",
			"format-muted": "",
			"format-icons": [ " ", " ", " " ],
			"on-click": "pavucontrol",
	},
	"network": {
		"interface": "wlp1s0",
		"format-wifi": "{essid} ({signalStrength}%)  ",
		"format-linked": "{ifname} (No IP) ✘ ",
		"format-disconnected": "Disconnected ✘ ",
		"format-alt": "{ifname}: {ipaddr}/{cidr}",
		"tooltip": false
	},
	"cpu": {
		"format": "{usage}%  ",
		"tooltip": false
	},
	"memory": {
		"format": "{}%  "
	},
	"backlight": {
		"device": "radeon_bl0",
		"format": "{percent}% {icon}",
		"format-icons":  [" ", " "]
	},
	"battery": {
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 15
		},
		"format": "{capacity}% {icon}",
		"format-charging": "{capacity}% 🗲 ",
		"format-plugged": "{capacity}%  ",
		"format-alt": "{time} {icon}",
		"format-icons": [" ", " ", " ", " ", " "]
	},
	"clock": {
		"format": "{:%H:%M %Z}",
		"format-alt": "{:%A, %B %d, %Y}",
		"tooltip": false,
		"actions": {
			"on-click-right": "mode"
		}
	}
}
