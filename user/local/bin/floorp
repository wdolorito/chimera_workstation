#!/bin/sh

#
# ~/local/bin/floorp
#

FLATPAK="$(which flatpak 2>/dev/null)"
PKG="one.ablaze.floorp"

do_err() {
	printf "%b" "$1"
	exit 127
}

if [ -z "$FLATPAK" ]
then
	do_err "\nflatpak command not available.\n\n"
fi

if ! $FLATPAK list | grep -q "$PKG" 2>/dev/null
then
	do_err "\n$PKG is not installed.\n\n"
fi

if env | grep -q DISPLAY
then
	$FLATPAK run "$PKG" "$@"
else
	echo "Not in a graphical session."
	exit 1
fi
