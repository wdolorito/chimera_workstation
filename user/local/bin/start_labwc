#!/bin/sh

#
# ~/local/bin/start_labwc
#

BACKGROUND="$HOME/Pictures/<image>"
GTK_THEME="Adwaita:dark"
OBSOCK="$(make_ob_sock 2>/dev/null)"
QT_QPA_PLATFORM="wayland"
MOZ_ENABLE_WAYLAND=1
LABWC="$(which labwc 2>/dev/null)"

run_session() {
	if [ -n "$LABWC" ]
	then
		export GTK_THEME
		export OBSOCK
		export QT_QPA_PLATFORM
		export MOZ_ENABLE_WAYLAND
		$LABWC
	else
		echo "labwc command not available."
		exit 127
	fi
}

reset_env() {
	unset GTK_THEME
	make_ob_sock destroy 2>/dev/null
	do_ob clean 2>/dev/null
	unset OBSOCK
	unset QT_QPA_PLATFORM
	unset MOZ_ENABLE_WAYLAND
	clear
}

set_background() {
	swaybg -i "$BACKGROUND" 2>/dev/null
}

set_idle() {
	lock_session reset 2>/dev/null
	swayidle -w \
		timeout 300 'lock_session' \
		timeout 600 'wlopm --off \*' \
		resume 'wlopm --on \*' \
		timeout 1200 'hybrid-sleep' 2>/dev/null
}

case "$1" in
	idle )
		set_idle
		;;
	background )
		set_background
		;;
	* )
		run_session
		reset_env
		;;
esac
